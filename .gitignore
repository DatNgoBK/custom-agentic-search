# Python build & cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/

# Test & lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# IDE / OS metadata
.vscode/
.idea/
*.swp
*.swo
.DS_Store
**/.DS_Store

# Secrets — never commit
.env
.env.local
*.local

# Runtime artifacts (regenerated by `make ingest` / Docker volume)
data/
qdrant_storage/
*.log
.ingestion_state.json

# Model caches
.cache/
models/

# Source PDF (too large; reviewer brings their own)
input/*.pdf

# Marker raw artifacts: keep markdown, drop binary images + meta JSON
output/**/*.png
output/**/*.jpg
output/**/*.jpeg
output/**/source_meta.json
!output/**/*.md

# Private / personal docs (interview prep, submission notes)
private/
SUBMISSION.md
