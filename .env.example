# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=dev-local-changeme
QDRANT_COLLECTION=msb_report_2024
QDRANT_TIMEOUT_SECONDS=30

# --- Embedding (OpenAI-compatible endpoint) ---
# Default: OpenRouter, which proxies OpenAI's text-embedding-3-small (1536d).
# To use a local server instead (e.g. TEI / mini sentence-transformers proxy),
# point EMBED_BASE_URL at it and clear EMBED_API_KEY if it doesn't require auth.
EMBED_BASE_URL=https://openrouter.ai/api/v1
EMBED_MODEL=openai/text-embedding-3-small
EMBED_DIM=1536
EMBED_API_KEY=sk-or-v1-PUT-YOUR-OPENROUTER-KEY-HERE

# --- Reranker ---
# Cohere rerank-v3.5 is routed through OpenRouter, so it reuses EMBED_API_KEY
# above — no separate Cohere account needed. The rerank section in ov.conf
# points at https://openrouter.ai/api/v1/rerank with model cohere/rerank-v3.5.
#
# To swap to a local reranker (e.g. TEI with bge-reranker-base), edit ov.conf
# directly and point api_base at localhost. The vars below are used by the
# optional `tei-rerank` Docker Compose profile.
RERANK_BASE_URL=http://localhost:8081
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_ENABLED=1

# --- OpenViking ---
OV_DATA_PATH=./data
OV_PROJECT_NAME=msb_demo

# --- Hybrid retrieval ---
ENABLE_SPARSE=1
RRF_K=60
DENSE_TOP_K=20
SPARSE_TOP_K=20
RERANK_TOP_K=5

# --- Observability ---
LOG_LEVEL=INFO
METRICS_PORT=9100
ENABLE_OTEL=0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
